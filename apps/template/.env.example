# Per-client identity
NEXT_PUBLIC_CLIENT_SLUG=cliente-slug
NEXT_PUBLIC_CLIENT_NAME="Cliente Display Name"
NEXT_PUBLIC_SITE_URL=https://cliente-domain.com

# Supabase (shared with zero-risk-platform prod)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@cliente-domain.com
CONTACT_EMAIL_TO=hello@cliente-domain.com

# Cloudflare Turnstile (form anti-spam)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=
CLOUDFLARE_TURNSTILE_SECRET_KEY=
